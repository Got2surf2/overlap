# Copy this file to .env.local for local development.
# In production (Vercel), set these as Project Environment Variables instead.

# From your Neon project: Dashboard -> Connection Details -> copy the
# "pooled connection" string (starts with postgresql://...).
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Shared passcode required to create a new poll.
# This is checked on the server (in the API route), never shipped to the browser.
CREATE_PASSCODE=letsmeet
